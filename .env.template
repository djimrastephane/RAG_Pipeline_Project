# Copy this file to .env and fill in values before running docker-compose.

# ── API server ──────────────────────────────────────────────────────────────
API_PORT=8000

# Leave blank to allow unauthenticated access from localhost only.
# Set a secret string to require X-API-Key header on all requests.
API_KEY=

# "auto" = require key when non-localhost origins are allowed
# "always" = always require key | "never" = never require key
API_KEY_POLICY=auto

# Comma-separated list of origins allowed to call the API.
UI_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Document upload ──────────────────────────────────────────────────────────
UPLOAD_ENABLED=0
MAX_UPLOAD_MB=20

# ── Preprocessing ────────────────────────────────────────────────────────────
# Enable mixed routing (prose + table extraction) for uploaded PDFs.
UI_MIXED_ROUTING=1
# Table chunking strategy: baseline | row_preserving | row_blocks | two_stage
UI_TABLE_CHUNKING_MODE=baseline

# ── Embedding ────────────────────────────────────────────────────────────────
# Device for sentence-transformer inference: cpu | mps | cuda
ST_MODEL_DEVICE=cpu

# ── Generation (Ollama) ──────────────────────────────────────────────────────
LOCAL_LLM_ENABLED=1
# When running via docker-compose this is overridden to http://ollama:11434.
# For local dev outside Docker, leave as default.
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=qwen2.5:7b-instruct
LOCAL_LLM_TIMEOUT_SECONDS=45
LOCAL_LLM_TEMPERATURE=0.1
LOCAL_LLM_TOP_P=0.9
LOCAL_LLM_MAX_TOKENS=220

# ── Retrieval re-ranking ─────────────────────────────────────────────────────
TABLE_CHUNK_BOOST=0.08
ENTITY_MATCH_BOOST=0.04
NUMERIC_DENSITY_BOOST=0.03
SEGMENT_SEARCH_HIT_BOOST=0.03
ENABLE_LEXICAL_RERANK=1
# Sections where the table boost is allowed to fire (comma-separated substrings).
TABLE_BOOST_ALLOWED_SECTION_PATTERNS=performance report,financial highlights,performance analysis,overview

# ── Rate limits ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQ_PER_MIN=60
RATE_LIMIT_SEARCH_PER_MIN=60
RATE_LIMIT_UPLOAD_PER_MIN=8
RATE_LIMIT_RANK_PER_MIN=20
RATE_LIMIT_READ_PER_MIN=120
