{
  "_meta": {
    "dataset_name": "NHS Grampian 2023-2024 Retrieval Gold Set",
    "description": "50-query golden dataset for evaluating RAG pipeline retrieval on the NHS Grampian Annual Report 2023-2024 (year ended 31 March 2024).",
    "doc_id": "Grampian-2023-2024",
    "query_id_format": "Q_2024_<CATEGORY>_<NN>",
    "year_note": "Year ended 31 March 2024",
    "category_codes": {
      "FIN": "Financial performance & targets",
      "SAV": "Efficiency savings",
      "IJB": "Integration Joint Boards",
      "AE": "A&E & Unscheduled Care",
      "DEL": "Delivery Plan",
      "ESC": "Escalation (Scottish Government)",
      "GOPES": "Grampian Operational Pressure Escalation System",
      "GOV": "Governance & management"
    },
    "paraphrase_marker": "_P1 / _P2 suffixes for paraphrase variants",
    "annotation_guidelines": "expected_answer is verbatim or near-verbatim from source; expected_pages are 1-indexed PDF page numbers",
    "difficulty_definition": {
      "LEX": "High lexical overlap with source",
      "MOD": "Moderate paraphrase",
      "STR": "Strong paraphrase / conceptual query"
    }
  },
