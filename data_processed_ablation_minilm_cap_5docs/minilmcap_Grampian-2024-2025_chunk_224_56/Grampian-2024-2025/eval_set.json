{
  "_meta": {
    "dataset_name": "Grampian-2024-2025 Retrieval Gold Set",
    "description": "Gold evaluation set for page-level retrieval benchmarking on NHS Grampian Annual Report 2024-2025.",
    "doc_id": "Grampian-2024-2025",
    "query_id_format": "Q_<YEAR>_<CATEGORY>_<INDEX>",
    "year_note": "2025 refers to financial year 2024-2025.",
    "category_codes": {
      "FIN": "Core financial performance (deficit, revenue limits, capital limits, expenditure)",
      "SAV": "Efficiency savings and cost improvement measures",
      "IJB": "Integration Joint Board financial performance",
      "AE": "A&E and emergency department performance metrics",
      "GOV": "Governance and statutory financial controls",
      "STR": "Strategic framework and long-term planning",
      "DEL": "Delivery Plan milestones and operational performance metrics",
      "ESC": "Escalation under NHS Scotland Support and Intervention Framework",
      "PLAN": "Forward financial planning statements",
      "GOPES": "Grampian Operational Pressure Escalation System"
    },
    "paraphrase_marker": "Queries with suffix _P1, _P2 indicate semantic paraphrase stress tests.",
    "annotation_guidelines": "Each query includes expected_pages and expected_answer. expected_answer must match the source page exactly.",
    "difficulty_definition": {
      "LEX": "High lexical overlap with document phrasing. Minimal semantic abstraction required.",
      "MOD": "Moderate paraphrase. Synonyms or minor phrasing changes require semantic matching.",
      "STR": "Strong paraphrase or conceptual query. Requires abstraction, aggregation, or non-trivial semantic mapping."
    }
  },
